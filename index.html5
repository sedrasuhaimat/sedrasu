<!DOCTYPE html>
<html>

<head>
    <title>Tables</title>
</head>

<body>

    <table border="1">

        <tr>
            <th>Name</th>
            <th>Age</th>
        </tr>

        <tr>
            <td>sedra</td>
            <td>20</td>
        </tr>

        <tr>
            <td>Sara</td>
            <td>21</td>
        </tr>

    </table>

</body>

</html>
