<!DOCTYPE html>
<html>

<head>

    <title>Borders</title>

    <style>

        h1 {
            border: 3px solid blue;
        }

        p {
            border: 2px dashed red;
            padding: 10px;
        }

    </style>

</head>

<body>

    <h1>Border Example</h1>

    <p>
        This paragraph has a dashed border.
    </p>

</body>
</head>
